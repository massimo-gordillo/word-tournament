# Expo / Supabase (required for the app)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Local DB seed only: used by `npm run supabase:seed` to write
# supabase/seed_play_review.generated.sql (not read by Postgres).
# Omit to use the documented default dev password.
SUPABASE_PLAY_REVIEW_PASSWORD=
SUPABASE_PLAY_REVIEW_EMAIL=
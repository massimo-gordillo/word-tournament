# Expo / Supabase (required for the app)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Local DB seed only: Google Play review account (npm run supabase:play-review-seed).
SUPABASE_PLAY_REVIEW_PASSWORD=
SUPABASE_PLAY_REVIEW_EMAIL=

# Optional: four (or LOCAL_TESTING_USER_COUNT) manual test logins after `npm run supabase:db:reset`.
# Use a single "!" in the email — it becomes 0, 1, 2, … (e.g. email!@hotmail.com -> email0@hotmail.com).
LOCAL_TESTING_EMAIL=
LOCAL_TESTING_PASSWORD=
# LOCAL_TESTING_USER_COUNT=4